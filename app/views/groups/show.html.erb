<div class="container px-5 px-sm-0">
  <h2>Group Detail</h2>

  <table class="table table-bordered align-middle">
    <thead>
      <tr>
        <th></th>
        <th>グループ名</th>
        <th>紹介文</th>
        <th>メンバー</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <tr>

        <!-- グループ画像 -->
        <td style="width:140px;">
          <% if @group.image.attached? %>
            <%= image_tag @group.image,
                style: "width:100px;height:100px;object-fit:cover;" %>
          <% else %>
            <%= image_tag "no_image.jpg",
                style: "width:100px;height:100px;object-fit:cover;" %>
          <% end %>
        </td>

        <!-- グループ名 -->
        <td>
          <strong><%= @group.name %></strong>
        </td>

        <!-- 紹介文 -->
        <td>
          <%= @group.introduction %>
        </td>

        <!-- メンバー -->
        <td>
          <% @group.users.each do |user| %>
            <div>
              <%= link_to user.name, user_path(user),
                  class: "text-decoration-none" %>
            </div>
          <% end %>
        </td>

        <!-- Join / Leave -->
        <td>
          <% if @group.owner_id == current_user.id %>
            <div class="d-flex flex-column gap-2">
              <span class="text-muted">Owner</span>
              <%= link_to "Edit",
                    edit_group_path(@group),
                    class: "btn btn-outline-secondary btn-sm" %>
              <%= link_to "Notice an Event",
                    new_mail_group_path(@group),
                    class: "btn btn-primary btn-sm" %>
            </div>

          <% elsif @group.group_users.exists?(user_id: current_user.id) %>
            <% group_user = @group.group_users.find_by(user_id: current_user.id) %>

            <%= button_to "Leave this group",
                  group_group_user_path(@group, group_user),
                  method: :delete,
                  class: "btn btn-outline-danger btn-sm" %>

          <% else %>
            <%= button_to "Join this group",
                  group_group_users_path(@group),
                  method: :post,
                  class: "btn btn-success btn-sm" %>
          <% end %>
        </td>
      </tr>
    </tbody>
  </table>

</div>
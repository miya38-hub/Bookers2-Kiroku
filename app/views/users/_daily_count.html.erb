<%= turbo_frame_tag "daily_count_frame" do %>
  <%= form_with url: daily_count_user_path(@user), method: :get do |f| %>
    <div class="d-flex gap-2 align-items-center">
      <%= f.date_field :date,
            value: (local_assigns[:date].presence || Time.zone.today),
            class: "form-control",
            style: "max-width: 220px;" %>
      <%= f.submit "表示", class: "btn btn-primary" %>
    </div>
  <% end %>

  <div class="mt-3 p-3 border rounded bg-light">
    <div>指定日：<strong><%= (local_assigns[:date].presence || Time.zone.today).strftime("%Y/%m/%d") %></strong></div>
    <div>投稿数：<strong><%= local_assigns[:count] %></strong></div>
  </div>
<% end %>
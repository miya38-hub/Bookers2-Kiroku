<div id="<%= dom_id(book, :favorite) %>">
  <% if book.favorited_by?(current_user) %>
    <%= button_to "❤️#{book.favorites.count}",
          book_favorite_path(book),
          method: :delete,
          class: "btn btn-link text-danger text-decoration-none fs-5 p-0" %>
  <% else %>
    <%= button_to "💙#{book.favorites.count}",
          book_favorite_path(book),
          method: :post,
          class: "btn btn-link text-muted text-decoration-none fs-5 p-0" %>
  <% end %>
</div>